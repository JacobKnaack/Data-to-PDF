  "license": "ISC",
  "description": "",
  "dependencies": {
    "express": "^5.2.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.3",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
